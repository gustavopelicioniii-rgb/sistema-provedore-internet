// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// ORGANIZATIONS (Multi-tenant)
// =====================================================

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  plan        String   @default("starter")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users            User[]
  clients         Client[]
  contracts       Contract[]
  plans           Plan[]
  invoices        Invoice[]
  tickets         Ticket[]
  serviceOrders   ServiceOrder[]
  leads           Lead[]
  conversations   Conversation[]
  automations     Automation[]
  equipment       Equipment[]
  ftthNodes       FtthNode[]
  technicians     Technician[]
  vehicles       Vehicle[]
  inventoryItems  InventoryItem[]
  bankTransactions BankTransaction[]
  auditLogs      AuditLog[]
  automationLogs  AutomationLog[]

  @@map("organizations")
}

// =====================================================
// USERS & AUTH
// =====================================================

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String
  fullName       String
  phone          String?
  avatarUrl      String?
  role           String   @default("technician")
  status         String   @default("active")
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  ticketsAssigned Ticket[] @relation("TicketAssignedTo")
  ticketsCreated Ticket[] @relation("TicketCreatedBy")
  serviceOrders ServiceOrder[]
  auditLogs     AuditLog[]

  @@map("users")
}

// =====================================================
// CLIENTS & CONTRACTS
// =====================================================

model Client {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name           String
  email          String?
  phone          String?
  document       String?
  documentType   String?
  
  street         String?
  number         String?
  complement     String?
  neighborhood   String?
  city           String?
  state          String?
  zipCode        String?
  latitude       Float?
  longitude      Float?
  
  status         String   @default("active")
  statusReason   String?
  
  metadata       Json     @default("{}")
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contracts      Contract[]
  invoices       Invoice[]
  tickets        Ticket[]
  serviceOrders  ServiceOrder[]
  leads          Lead?

  @@map("clients")
}

model Contract {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  clientId       String
  client         Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  planId         String
  plan           Plan @relation(fields: [planId], references: [id])
  
  status         String   @default("active")
  startDate      DateTime
  endDate        DateTime?
  
  username       String?
  password       String?
  
  installationAddress String?
  
  metadata       Json     @default("{}")
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  invoices       Invoice[]

  @@map("contracts")
}

model Plan {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name           String
  downloadSpeed  Int
  uploadSpeed    Int
  price          Decimal  @db.Decimal(10, 2)
  description    String?
  technology     String   @default("fiber")
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contracts      Contract[]
  
  @@map("plans")
}

// =====================================================
// FINANCES
// =====================================================

model Invoice {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  clientId       String
  client         Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  contractId     String?
  contract       Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  
  number         String?
  referenceMonth String
  dueDate        DateTime
  amount         Decimal  @db.Decimal(10, 2)
  discount       Decimal  @default(0) @db.Decimal(10, 2)
  
  status         String   @default("pending")
  paidAt         DateTime?
  paidAmount     Decimal? @db.Decimal(10, 2)
  paymentMethod   String?
  paymentProof   String?
  
  nfeNumber      String?
  nfeKey         String?
  nfeStatus      String?
  
  pixCode        String?
  barcode        String?
  
  metadata       Json     @default("{}")
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("invoices")
}

model BankTransaction {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  bankCode       String?
  agency         String?
  account        String?
  
  date           DateTime
  amount         Decimal  @db.Decimal(10, 2)
  type           String
  description    String?
  
  category       String?
  invoiceId      String?
  status         String   @default("unmatched")
  
  rawData        Json?
  
  createdAt      DateTime @default(now())

  @@map("bank_transactions")
}

// =====================================================
// TICKETS & SERVICE ORDERS
// =====================================================

model Ticket {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  clientId       String?
  client         Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  
  subject        String
  description    String?
  priority       String   @default("medium")
  status         String   @default("open")
  
  assignedToId   String?
  assignedTo     User? @relation("TicketAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  
  createdById    String
  createdBy      User? @relation("TicketCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  
  resolvedAt     DateTime?
  closedAt       DateTime?
  
  metadata       Json     @default("{}")
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("tickets")
}

model ServiceOrder {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  clientId       String
  client         Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  number         String   @unique
  type           String
  status         String   @default("open")
  priority       String   @default("medium")
  
  description    String?
  scheduledDate  DateTime?
  completedAt    DateTime?
  
  technicianId   String?
  technician     Technician? @relation(fields: [technicianId], references: [id], onDelete: SetNull)
  
  createdById    String
  createdBy      User @relation(fields: [createdById], references: [id], onDelete: Cascade)
  
  address        String?
  
  metadata       Json     @default("{}")
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("service_orders")
}

// =====================================================
// CRM & LEADS
// =====================================================

model Lead {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  clientId       String?  @unique
  client         Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  
  name           String
  email          String?
  phone          String?
  source         String?
  stage          String   @default("new")
  pipeline       String   @default("default")
  
  interest       String?
  budget         Decimal? @db.Decimal(10, 2)
  
  lostReason     String?
  wonAt          DateTime?
  
  metadata       Json     @default("{}")
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("leads")
}

// =====================================================
// CHAT & CONVERSATIONS
// =====================================================

model Conversation {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  channel        String
  externalId     String?
  
  clientId       String?
  clientName     String?
  clientPhone    String?
  
  status         String   @default("open")
  
  lastMessageAt  DateTime?
  lastMessagePreview String?
  
  metadata       Json     @default("{}")
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("conversations")
}

// =====================================================
// AUTOMATIONS
// =====================================================

model Automation {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name           String
  description    String?
  
  category       String
  triggerType    String
  triggerConfig Json     @default("{}")
  
  actionType     String
  actionConfig   Json     @default("{}")
  
  enabled        Boolean  @default(true)
  lastTriggeredAt DateTime?
  
  webhookUrl     String?
  webhookSecret  String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  logs           AutomationLog[]

  @@map("automations")
}

model AutomationLog {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  automationId   String
  automation     Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  
  status         String
  triggerPayload Json?
  responsePayload Json?
  errorMessage   String?
  
  executedAt     DateTime @default(now())

  @@map("automation_logs")
}

// =====================================================
// EQUIPMENT
// =====================================================

model Equipment {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name           String
  type           String
  ipAddress      String
  port           Int      @default(80)
  
  location       String?
  model          String?
  firmware       String?
  
  status         String   @default("unknown")
  lastCheck      DateTime?
  
  metadata       Json     @default("{}")
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("equipments")
}

// =====================================================
// FTTH / REDE FIBRA
// =====================================================

model FtthNode {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name           String
  type           String
  latitude       Float?
  longitude      Float?
  
  parentId       String?
  
  totalPorts     Int?
  usedPorts      Int      @default(0)
  status         String   @default("active")
  
  metadata       Json     @default("{}")
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("ftth_nodes")
}

// =====================================================
// TECHNICIANS & VEHICLES
// =====================================================

model Technician {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  userId         String?  @unique
  name           String
  email          String?
  phone          String?
  
  specialty      String   @default("general")
  status         String   @default("available")
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  serviceOrders  ServiceOrder[]

  @@map("technicians")
}

model Vehicle {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  plate          String
  model          String
  type           String
  status         String   @default("available")
  
  fuelLevel      Int?
  mileage        Int?
  driverName     String?
  
  nextMaintenance DateTime?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("vehicles")
}

// =====================================================
// INVENTORY
// =====================================================

model InventoryItem {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name           String
  category       String?
  sku            String?
  
  quantity       Int      @default(0)
  minQuantity    Int      @default(0)
  unit           String   @default("un")
  price          Decimal? @db.Decimal(10, 2)
  
  location       String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("inventory_items")
}

// =====================================================
// AUDIT LOG
// =====================================================

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  userId         String?
  user           User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName       String?
  
  action         String
  entityType     String
  entityId       String?
  
  details        Json?
  ipAddress      String?
  
  createdAt      DateTime @default(now())

  @@map("audit_logs")
}
